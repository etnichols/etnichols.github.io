# pnpm configuration

# Use node-modules linker (same behavior as yarn's nodeLinker: node-modules)
# Required for compatibility with packages that don't support pnpm's default symlink approach
node-linker=hoisted

# Hoist esbuild and its platform binaries to root node_modules so nested
# packages like @contentlayer2/core can resolve them (fixes Vercel build error:
# "could not find a copy of esbuild to link")
public-hoist-pattern[]=*esbuild*

# Silence peer dependency warnings during install
strict-peer-dependencies=false
